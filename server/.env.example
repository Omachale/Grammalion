# Copy this to .env and fill in values for local development.
# Do NOT commit .env — it is in .gitignore.

# PostgreSQL connection string.
# Leave blank to run server without persistence (game still works).
DATABASE_URL=

# Origin of the Phaser client (used for CORS).
# During local dev this is the webpack-dev-server port.
CLIENT_ORIGIN=http://localhost:8080

# Server port (Render sets this automatically in production).
PORT=3000
